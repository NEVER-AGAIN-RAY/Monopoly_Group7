<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<TabPane fx:id="rootTabPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.monopoly.fx.MainController" tabClosingPolicy="UNAVAILABLE">

    <!-- ==================== 对局主 Tab ==================== -->
    <Tab fx:id="gameTab" text="对局">
        <BorderPane>

            <top>
                <VBox spacing="6.0">
                    <padding>
                        <Insets bottom="6.0" left="12.0" right="12.0" top="10.0"/>
                    </padding>

                    <!-- ===== 快速开始卡片（游戏前显示） ===== -->
                    <VBox fx:id="quickStartCard" spacing="10.0" styleClass="quick-start-card"
                          alignment="CENTER">
                        <Label fx:id="appTitleLabel" text="Monopoly Deal" styleClass="quick-start-title"/>
                        <Label fx:id="appSubtitleLabel" text="选择模式，点击开始即可游玩" styleClass="quick-start-subtitle"/>

                        <HBox spacing="16.0" alignment="CENTER">
                            <VBox spacing="4.0" alignment="CENTER">
                                <Label fx:id="gameModeLabel" text="游戏模式" style="-fx-font-weight: bold;"/>
                                <ComboBox fx:id="gameModeCombo" prefWidth="160.0"/>
                            </VBox>
                            <VBox spacing="4.0" alignment="CENTER">
                                <Label fx:id="playerCountLabel" text="玩家人数" style="-fx-font-weight: bold;"/>
                                <Spinner fx:id="playerCountSpinner" editable="false"/>
                            </VBox>
                            <VBox fx:id="aiDifficultyBox" spacing="4.0" alignment="CENTER">
                                <Label fx:id="aiDifficultyLabel" text="AI 难度" style="-fx-font-weight: bold;"/>
                                <ComboBox fx:id="aiDifficultyCombo" prefWidth="120.0"/>
                            </VBox>
                            <VBox spacing="4.0" alignment="CENTER">
                                <Label fx:id="languageLabel" text="语言" style="-fx-font-weight: bold;"/>
                                <ComboBox fx:id="languageCombo" prefWidth="120.0"/>
                            </VBox>
                        </HBox>

                        <Label fx:id="modeHintLabel" wrapText="true" style="-fx-text-fill: #546e7a; -fx-font-size: 12px;"/>

                        <Button fx:id="startGameButton" mnemonicParsing="false" onAction="#onQuickAuthAndStart"
                                text="开始游戏" styleClass="btn-start-game"/>

                        <Button fx:id="showGuideButton" mnemonicParsing="false" onAction="#onShowGuide"
                                text="如何多人联机？点此查看说明" styleClass="btn-guide-link"/>

                        <Label fx:id="errorLabel" wrapText="true" visible="false" managed="false"
                               style="-fx-text-fill: #b71c1c; -fx-font-weight: bold;"/>

                        <!-- 高级设置（默认折叠） -->
                        <TitledPane fx:id="advancedPane" text="高级设置（服务器地址、玩家ID 等）" collapsible="true" expanded="false">
                            <VBox spacing="4.0">
                                <padding>
                                    <Insets bottom="6.0" left="4.0" right="4.0" top="4.0"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <Label fx:id="serverLabel" text="服务器" style="-fx-font-weight: bold;" prefWidth="56.0"/>
                                    <TextField fx:id="wsUrlField" prefWidth="320.0" HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="connectButton" mnemonicParsing="false" onAction="#onConnect" text="连接"/>
                                    <Label fx:id="statusLabel" text="未连接"/>
                                </HBox>
                                <GridPane hgap="10.0" vgap="4.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="NEVER" minWidth="56.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                                        <ColumnConstraints hgrow="NEVER" minWidth="56.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                                    </columnConstraints>
                                    <Label fx:id="playerIdLabel" text="玩家 ID" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <TextField fx:id="playerIdField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <Label fx:id="sessionIdLabel" text="会话 ID" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                    <TextField fx:id="sessionIdField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                </GridPane>
                                <CheckBox fx:id="randomizeFirstCheck" mnemonicParsing="false" text="随机先手"/>
                                <HBox spacing="8.0">
                                    <Button fx:id="authOnlyButton" mnemonicParsing="false" onAction="#onAuth" text="仅认证"/>
                                    <Button fx:id="startOnlyButton" mnemonicParsing="false" onAction="#onStartSession" text="仅开局"/>
                                    <Button mnemonicParsing="false" onAction="#onPing" text="PING"/>
                                </HBox>
                            </VBox>
                        </TitledPane>
                    </VBox>

                    <!-- ===== 游戏中状态栏（游戏开始后显示） ===== -->
                    <HBox fx:id="gameStatusBar" spacing="12.0" alignment="CENTER_LEFT"
                          visible="false" managed="false">
                        <Label fx:id="summaryLabel" wrapText="true" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 12px;"/>
                        <Button fx:id="disconnectButton" disable="true" mnemonicParsing="false"
                                onAction="#onDisconnect" text="断开" styleClass="btn-disconnect"/>
                    </HBox>
                    <Label fx:id="errorLabelInGame" wrapText="true" visible="false" managed="false"
                           style="-fx-text-fill: #b71c1c; -fx-font-weight: bold;"/>
                </VBox>
            </top>

            <center>
                <VBox spacing="6.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="10.0" right="10.0" top="4.0"/>
                    </padding>

                    <!-- 操作引导面板 -->
                    <VBox fx:id="actionGuidePanel" spacing="4.0" styleClass="action-guide">
                        <Label fx:id="actionGuideTitle" styleClass="action-guide-title"
                               text="欢迎来到 Monopoly Deal"/>
                        <Label fx:id="actionGuideStep1" styleClass="action-guide-step"
                               text="选择模式，点击上方「开始游戏」。"/>
                    </VBox>

                    <!-- 租金支付 -->
                    <VBox fx:id="rentPaymentBox" spacing="6.0" visible="false" managed="false">
                        <Label fx:id="rentPaymentHint" wrapText="true" style="-fx-font-weight: bold;"/>
                        <Label fx:id="rentPaymentSumLabel" wrapText="true" style="-fx-text-fill: #37474f;"/>
                        <FlowPane fx:id="rentPaymentPickPane" hgap="6.0" vgap="6.0"/>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <Button fx:id="rentPaymentGreedyButton" mnemonicParsing="false"
                                    onAction="#onRentPaymentGreedy" text="自动选牌（推荐）"
                                    styleClass="btn-auto"/>
                            <Button fx:id="rentPaymentSubmitButton" mnemonicParsing="false"
                                    onAction="#onRentPaymentSubmit" text="确认支付"
                                    styleClass="btn-confirm"/>
                            <Button fx:id="rentPaymentClearButton" mnemonicParsing="false"
                                    onAction="#onRentPaymentClear" text="清空"/>
                        </HBox>
                    </VBox>

                    <!-- 玩家桌面 -->
                    <Label fx:id="boardsTitle" text="玩家桌面" visible="false" managed="false"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #37474f;"/>
                    <ScrollPane fx:id="boardsScrollPane" fitToHeight="true" hbarPolicy="AS_NEEDED"
                                vbarPolicy="AS_NEEDED" prefHeight="380.0"
                                visible="false" managed="false">
                        <HBox fx:id="playerBoardContainer" spacing="12.0">
                            <padding>
                                <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                            </padding>
                        </HBox>
                    </ScrollPane>

                    <!-- 手牌区 -->
                    <HBox fx:id="handHeader" alignment="CENTER_LEFT" spacing="8.0"
                          visible="false" managed="false">
                        <Label fx:id="myHandLabel" text="我的手牌" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Label fx:id="selectedCardLabel" text="点选一张牌后，用下方按钮出牌"
                               style="-fx-text-fill: #546e7a;"/>
                    </HBox>
                    <ScrollPane fx:id="handScroll" fitToWidth="true" hbarPolicy="AS_NEEDED"
                                prefHeight="220.0" visible="false" managed="false">
                        <HBox fx:id="handStrip" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="8.0" right="8.0" top="6.0"/>
                            </padding>
                        </HBox>
                    </ScrollPane>
                </VBox>
            </center>

            <bottom>
                <VBox fx:id="actionBar" spacing="8.0" visible="false" managed="false">
                    <padding>
                        <Insets bottom="10.0" left="12.0" right="12.0" top="8.0"/>
                    </padding>
                    <HBox spacing="8.0">
                        <Button fx:id="drawButton" mnemonicParsing="false" onAction="#onDraw" text="摸 2 张牌"
                                style="-fx-font-weight: bold;"/>
                        <Button fx:id="endTurnButton" mnemonicParsing="false" onAction="#onEndTurn" text="结束回合"/>
                    </HBox>
                    <Label fx:id="playHintLabel" text="出牌（先点选手牌）" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <FlowPane hgap="10.0" vgap="8.0">
                        <Button fx:id="wizardDepositButton" mnemonicParsing="false" onAction="#onWizardDeposit"
                                text="存入银行" styleClass="btn-deposit"/>
                        <Button fx:id="wizardDeployButton" mnemonicParsing="false" onAction="#onWizardDeploy"
                                text="部署房产" styleClass="btn-deploy"/>
                        <Button fx:id="wizardActionButton" mnemonicParsing="false" onAction="#onWizardAction"
                                text="打出行动牌" styleClass="btn-action"/>
                        <Button fx:id="wizardDiscardButton" mnemonicParsing="false" onAction="#onWizardDiscard"
                                text="弃牌" styleClass="btn-discard"/>
                    </FlowPane>
                </VBox>
            </bottom>
        </BorderPane>
    </Tab>

    <!-- ==================== 游戏规则 Tab ==================== -->
    <Tab fx:id="rulesTab" text="游戏规则">
        <BorderPane>
            <center>
                <WebView fx:id="rulesWebView" prefHeight="600.0"/>
            </center>
        </BorderPane>
    </Tab>

    <!-- ==================== 联机指南 Tab ==================== -->
    <Tab fx:id="guideTab" text="联机指南">
        <BorderPane>
            <center>
                <WebView fx:id="guideWebView" prefHeight="600.0"/>
            </center>
        </BorderPane>
    </Tab>

    <!-- ==================== 调试日志 Tab ==================== -->
    <Tab fx:id="debugTab" text="调试日志">
        <BorderPane>
            <top>
                <VBox spacing="6.0">
                    <padding>
                        <Insets bottom="6.0" left="10.0" right="10.0" top="8.0"/>
                    </padding>
                    <HBox spacing="8.0">
                        <Button fx:id="clearLogButton" mnemonicParsing="false" onAction="#onClearTraffic" text="清空日志"/>
                    </HBox>
                    <Accordion>
                        <panes>
                            <TitledPane fx:id="debugTitledPane" animated="false" expanded="false" text="调试：手动填写参数（可选）">
                                <GridPane hgap="8.0" vgap="6.0">
                                    <padding>
                                        <Insets bottom="8.0" left="8.0" right="8.0" top="6.0"/>
                                    </padding>
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="NEVER"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0"/>
                                        <ColumnConstraints hgrow="NEVER"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0"/>
                                    </columnConstraints>
                                    <Label fx:id="debugActionLabel" text="动作" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <ComboBox fx:id="playActionCombo" prefWidth="140.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <HBox spacing="8.0" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="0">
                                        <Button fx:id="wizardPlayButton" mnemonicParsing="false" onAction="#onPlay" text="向导：先拉选项再出牌"/>
                                        <Button fx:id="directPlayButton" mnemonicParsing="false" onAction="#onPlayDirect" text="跳过选项直接 PLAY"/>
                                    </HBox>
                                    <Label text="cardId" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <TextField fx:id="playCardIdField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    <Label text="targetPlayer" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                    <TextField fx:id="targetPlayerField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                                    <Label text="targetColor" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <TextField fx:id="targetColorField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                    <Label text="targetCard" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                    <TextField fx:id="targetCardField" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                                    <Label text="actorCard" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                    <TextField fx:id="actorCardField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                    <Label text="targetZone" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                                    <TextField fx:id="targetZoneField" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
                                    <Label text="actingPlayer" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                    <TextField fx:id="actingPlayerField" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="4"/>
                                </GridPane>
                            </TitledPane>
                        </panes>
                    </Accordion>
                </VBox>
            </top>
            <center>
                <AnchorPane>
                    <TextArea fx:id="trafficArea" wrapText="true" style="-fx-font-family: monospace;"
                              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
                </AnchorPane>
            </center>
        </BorderPane>
    </Tab>
</TabPane>
