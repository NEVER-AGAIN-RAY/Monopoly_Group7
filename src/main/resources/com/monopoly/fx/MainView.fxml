<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<TabPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.monopoly.fx.MainController" tabClosingPolicy="UNAVAILABLE">
    <Tab text="对局">
        <BorderPane>
            <top>
                <VBox spacing="8.0">
                    <padding>
                        <Insets bottom="8.0" left="12.0" right="12.0" top="10.0"/>
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="服务器" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="wsUrlField" prefWidth="320.0" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="connectButton" mnemonicParsing="false" onAction="#onConnect" text="连接"/>
                        <Button fx:id="disconnectButton" disable="true" mnemonicParsing="false" onAction="#onDisconnect" text="断开"/>
                        <Label fx:id="statusLabel" text="未连接"/>
                    </HBox>
                    <Separator/>
                    <GridPane hgap="10.0" vgap="6.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="NEVER" minWidth="56.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                            <ColumnConstraints hgrow="NEVER" minWidth="56.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                            <ColumnConstraints hgrow="NEVER"/>
                            <ColumnConstraints hgrow="NEVER" minWidth="72.0"/>
                        </columnConstraints>
                        <Label text="玩家 ID" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="playerIdField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="会话 ID" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <TextField fx:id="sessionIdField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                        <Label text="人数" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                        <Spinner fx:id="playerCountSpinner" editable="false" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                        <Label text="模式" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="gameModeCombo" prefWidth="140.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label fx:id="aiDifficultyLabel" text="AI 难度" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="aiDifficultyCombo" prefWidth="120.0" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                        <CheckBox fx:id="randomizeFirstCheck" mnemonicParsing="false" text="随机先手"
                                  GridPane.columnIndex="4" GridPane.columnSpan="2" GridPane.rowIndex="1"/>
                    </GridPane>
                    <Label fx:id="modeHintLabel" wrapText="true" style="-fx-text-fill: #546e7a;"/>
                    <HBox spacing="8.0">
                        <Button mnemonicParsing="false" onAction="#onQuickAuthAndStart"
                                text="① 认证并开局" style="-fx-font-weight: bold;"/>
                        <Button mnemonicParsing="false" onAction="#onAuth" text="仅认证"/>
                        <Button mnemonicParsing="false" onAction="#onStartSession" text="仅开局"/>
                        <Button mnemonicParsing="false" onAction="#onPing" text="PING"/>
                    </HBox>
                    <Label fx:id="summaryLabel" wrapText="true" style="-fx-font-size: 13px;"/>
                    <Label fx:id="errorLabel" wrapText="true" visible="false" managed="false"
                           style="-fx-text-fill: #b71c1c; -fx-font-weight: bold;"/>
                </VBox>
            </top>
            <center>
                <VBox spacing="8.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="10.0" right="10.0" top="4.0"/>
                    </padding>
                    <Label fx:id="turnGuideLabel" wrapText="true" styleClass="turn-guide"
                           text="连接并开局后，这里会提示你是否轮到你操作。"/>
                    <VBox fx:id="rentPaymentBox" spacing="6.0" visible="false" managed="false">
                        <Label fx:id="rentPaymentHint" wrapText="true" style="-fx-font-weight: bold;"/>
                        <Label fx:id="rentPaymentSumLabel" wrapText="true" style="-fx-text-fill: #37474f;"/>
                        <FlowPane fx:id="rentPaymentPickPane" hgap="6.0" vgap="6.0"/>
                        <HBox spacing="8.0">
                            <Button fx:id="rentPaymentSubmitButton" mnemonicParsing="false"
                                    onAction="#onRentPaymentSubmit" text="按所选支付并放弃免租"/>
                            <Button fx:id="rentPaymentGreedyButton" mnemonicParsing="false"
                                    onAction="#onRentPaymentGreedy" text="自动选牌（小面额优先）"/>
                            <Button fx:id="rentPaymentClearButton" mnemonicParsing="false"
                                    onAction="#onRentPaymentClear" text="清空勾选"/>
                        </HBox>
                    </VBox>
                    <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" prefHeight="210.0">
                        <HBox fx:id="playerBoardContainer" spacing="12.0">
                            <padding>
                                <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                            </padding>
                        </HBox>
                    </ScrollPane>
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="我的手牌" style="-fx-font-weight: bold;"/>
                        <Label fx:id="selectedCardLabel" text="点选一张牌后，用下方彩色按钮出牌"
                               style="-fx-text-fill: #37474f;"/>
                    </HBox>
                    <ScrollPane fx:id="handScroll" fitToWidth="true" hbarPolicy="AS_NEEDED" prefHeight="240.0">
                        <HBox fx:id="handStrip" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="8.0" right="8.0" top="6.0"/>
                            </padding>
                        </HBox>
                    </ScrollPane>
                </VBox>
            </center>
            <bottom>
                <VBox spacing="8.0">
                    <padding>
                        <Insets bottom="10.0" left="12.0" right="12.0" top="8.0"/>
                    </padding>
                    <HBox spacing="8.0">
                        <Button mnemonicParsing="false" onAction="#onDraw" text="摸 2 张牌"/>
                        <Button mnemonicParsing="false" onAction="#onEndTurn" text="结束回合"/>
                    </HBox>
                    <Label text="出牌（先点选手牌）" style="-fx-font-weight: bold;"/>
                    <FlowPane hgap="8.0" vgap="8.0">
                        <Button fx:id="wizardDepositButton" mnemonicParsing="false" onAction="#onWizardDeposit" text="存入银行"/>
                        <Button fx:id="wizardDeployButton" mnemonicParsing="false" onAction="#onWizardDeploy" text="部署房产"/>
                        <Button fx:id="wizardActionButton" mnemonicParsing="false" onAction="#onWizardAction" text="打出行动牌"/>
                        <Button fx:id="wizardDiscardButton" mnemonicParsing="false" onAction="#onWizardDiscard" text="弃牌"/>
                    </FlowPane>
                    <Accordion>
                        <panes>
                            <TitledPane animated="false" expanded="false" text="调试：手动填写参数（可选）">
                                <GridPane hgap="8.0" vgap="6.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="NEVER"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0"/>
                                        <ColumnConstraints hgrow="NEVER"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0"/>
                                    </columnConstraints>
                                    <Label text="动作" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <ComboBox fx:id="playActionCombo" prefWidth="140.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <HBox spacing="8.0" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="0">
                                        <Button mnemonicParsing="false" onAction="#onPlay" text="向导：先拉选项再出牌"/>
                                        <Button mnemonicParsing="false" onAction="#onPlayDirect" text="跳过选项直接 PLAY"/>
                                    </HBox>
                                    <Label text="cardId" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <TextField fx:id="playCardIdField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    <Label text="targetPlayer" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                    <TextField fx:id="targetPlayerField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                                    <Label text="targetColor" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <TextField fx:id="targetColorField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                    <Label text="targetCard" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                    <TextField fx:id="targetCardField" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                                    <Label text="actorCard" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                    <TextField fx:id="actorCardField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                    <Label text="targetZone" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                                    <TextField fx:id="targetZoneField" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
                                    <Label text="actingPlayer" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                    <TextField fx:id="actingPlayerField" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="4"/>
                                </GridPane>
                            </TitledPane>
                        </panes>
                    </Accordion>
                </VBox>
            </bottom>
        </BorderPane>
    </Tab>
    <Tab text="游戏规则">
        <BorderPane>
            <center>
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <TextArea fx:id="rulesTextArea" wrapText="true" editable="false"
                              prefRowCount="24" style="-fx-font-size: 12px;"/>
                </ScrollPane>
            </center>
        </BorderPane>
    </Tab>
    <Tab text="调试日志">
        <BorderPane>
            <top>
                <HBox spacing="8.0">
                    <padding>
                        <Insets bottom="6.0" left="10.0" right="10.0" top="8.0"/>
                    </padding>
                    <Button mnemonicParsing="false" onAction="#onClearTraffic" text="清空日志"/>
                </HBox>
            </top>
            <center>
                <AnchorPane>
                    <TextArea fx:id="trafficArea" wrapText="true" style="-fx-font-family: monospace;"
                              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
                </AnchorPane>
            </center>
        </BorderPane>
    </Tab>
</TabPane>
